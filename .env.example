# ============================================
# TUITION MARKETPLACE - PRODUCTION ENVIRONMENT
# AWS EC2 + Local MongoDB + CloudFront
# ============================================

# Server Configuration
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Database Configuration - Local MongoDB on EC2
MONGODB_URI=mongodb://127.0.0.1:27017/tuitionAppDB
MONGODB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRE=7d

# CORS Configuration - Allowed Origins
# Production: https://hometuitionapp.com
# Local development: http://localhost:3000, http://localhost:19006
ALLOWED_ORIGINS=https://hometuitionapp.com,https://www.hometuitionapp.com,http://localhost:3000,http://localhost:19006,http://localhost:5000
FRONTEND_URL=https://hometuitionapp.com

# CORS Methods & Headers
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin
CORS_CREDENTIALS=true

# Security Settings
TRUST_PROXY=true
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Settings
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Socket.IO
SOCKET_CORS_ORIGIN=https://hometuitionapp.com

# Feature Flags - Disable unused services
ENABLE_MONGODB_ATLAS=false
ENABLE_FIREBASE=false
ENABLE_RAZORPAY_LIVE=false
ENABLE_TWILIO=false
ENABLE_AWS_S3=false

# Placeholder for future services (keep disabled until configured)
# CLOUDINARY_CLOUD_NAME=placeholder
# CLOUDINARY_API_KEY=placeholder
# CLOUDINARY_API_SECRET=placeholder

# RAZORPAY_KEY_ID=rzp_test_placeholder
# RAZORPAY_KEY_SECRET=placeholder

# FIREBASE_PROJECT_ID=placeholder
# FIREBASE_PRIVATE_KEY=placeholder
# FIREBASE_CLIENT_EMAIL=placeholder

# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=placeholder
# EMAIL_PASS=placeholder

# GOOGLE_MAPS_API_KEY=placeholder

# ============================================
# DEPLOYMENT NOTES:
# 1. Copy this file to .env and fill in actual values
# 2. Ensure JWT_SECRET is at least 32 characters
# 3. MongoDB must be running locally on EC2
# 4. Update CloudFront origin to point to EC2 IP
# 5. Security group must allow port 5000 from localhost only
# ============================================
